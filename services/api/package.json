{
  "name": "@conference/api",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node -e \"console.log('api: no tests yet')\"",
    "prisma:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma --name init_mvp",
    "prisma:studio": "prisma studio --schema ../../prisma/schema.prisma",
    "prisma:seed": "pnpm seed",
    "seed": "prisma db seed --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@conference/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/node": "^22.10.7",
    "prisma": "^6.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx ../../prisma/seed.ts"
  }
}
