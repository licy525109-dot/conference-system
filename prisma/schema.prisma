generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConferenceStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum RegistrationSkuStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  CLOSED
  REFUNDED
}

enum PaymentProvider {
  MOCK
  WECHAT
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CLOSED
}

enum DiscountType {
  FULL_REDUCTION
  COUPON
  MEMBER_PRICE
}

enum CouponType {
  AMOUNT
  PERCENT
}

enum CouponScope {
  CONFERENCE
  MALL
  BOTH
}

enum CouponRedemptionStatus {
  PENDING
  USED
  CANCELLED
}

enum RegistrationStatus {
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum CheckInStatus {
  NOT_REQUIRED
  PENDING
  CHECKED_IN
  CANCELLED
}

enum FormFieldType {
  TEXT
  TEXTAREA
  PHONE
  EMAIL
  SELECT
  RADIO
  CHECKBOX
  DATE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  SYSTEM
}

enum NotificationChannelType {
  MOCK
  WECHAT_SUBSCRIBE
  SMS
}

enum NotificationTemplateStatus {
  DRAFT
  ACTIVE
  DISABLED
}

enum NotificationTaskStatus {
  DRAFT
  PENDING
  SENDING
  SENT
  PARTIAL_FAILED
  FAILED
  CANCELLED
  SKIPPED
}

enum NotificationLogStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

enum CustomerGroupMessageStatus {
  DRAFT
  CREATED
  WAITING_CONFIRM
  SENDING
  SENT
  PARTIAL_FAILED
  FAILED
  SKIPPED
  CANCELLED
}

enum WecomAuthMode {
  SELF_BUILT_APP
  LEGACY_CUSTOMER_CONTACT
}

enum CheckinActionType {
  VERIFY
  MANUAL
  SELF_INPUT
  QR_SCAN
  ADMIN_MANUAL
  REVOKE
}

enum RefundStatus {
  REQUESTED
  APPROVED
  PROCESSING
  SUCCESS
  FAILED
  REJECTED
}

enum InvoiceStatus {
  REQUESTED
  APPROVED
  REJECTED
  ISSUED
}

enum CouponClaimStatus {
  CLAIMED
  USED
  EXPIRED
  CANCELLED
}

enum SaasTenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum SaasWorkspaceStatus {
  ACTIVE
  DISABLED
}

enum SaasSubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum PlatformCredentialStatus {
  ACTIVE
  REVOKED
}

enum PlatformPluginInstallStatus {
  ACTIVE
  DISABLED
  FAILED
}

model User {
  id                        String                     @id @default(cuid())
  openid                    String?                    @unique
  unionid                   String?
  nickname                  String?
  wechatNickname            String?
  wechatAvatarUrl           String?
  profileUpdatedAt          DateTime?
  lastActiveAt              DateTime?
  phone                     String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  orders                    Order[]
  registrations             Registration[]
  couponRedemptions         CouponRedemption[]
  mallCouponRedemptions     MallCouponRedemption[]
  conferenceAppointments    ConferenceAppointment[]
  memberships               UserMembership[]
  cartItems                 CartItem[]
  registrationCartItems     RegistrationCartItem[]
  mallOrders                MallOrder[]
  notificationSubscriptions NotificationSubscription[]
  notificationLogs          NotificationLog[]
  adminWechatBindings       AdminWechatBinding[]
  checkinStaffAssignments   CheckinStaffAssignment[]
  couponClaims              CouponClaim[]
  refunds                   Refund[]
  invoiceApplications       InvoiceApplication[]
  invoiceProfiles           InvoiceProfile[]
  memberBenefitGrants       MemberBenefitGrant[]

  @@index([createdAt])
  @@index([lastActiveAt])
  @@map("users")
}

model AdminUser {
  id                    String                 @id @default(cuid())
  username              String                 @unique
  passwordHash          String
  displayName           String?
  enabled               Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  auditLogs             AuditLog[]
  roles                 AdminUserRole[]
  mobileBindings        AdminWechatBinding[]
  notificationTemplates NotificationTemplate[] @relation("NotificationTemplateCreatedBy")
  notificationTasks     NotificationTask[]     @relation("NotificationTaskCreatedBy")
  checkinLogs           CheckinLog[]
  saasTenantMemberships SaasTenantMember[]

  @@index([enabled])
  @@index([createdAt])
  @@map("admin_users")
}

model SaasTenant {
  id             String                  @id @default(cuid())
  slug           String                  @unique
  name           String
  status         SaasTenantStatus        @default(ACTIVE)
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  settingsJson   Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  organizations  SaasOrganization[]
  workspaces     SaasWorkspace[]
  members        SaasTenantMember[]
  subscriptions  SaasSubscription[]
  apiKeys        PlatformApiKey[]
  webhooks       PlatformWebhook[]
  usageEvents    PlatformUsageEvent[]
  pluginInstalls PlatformPluginInstall[]
  featureFlags   PlatformFeatureFlag[]

  @@index([status])
  @@index([createdAt])
  @@map("saas_tenants")
}

model SaasOrganization {
  id          String          @id @default(cuid())
  tenantId    String
  code        String
  name        String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  tenant      SaasTenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaces  SaasWorkspace[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("saas_organizations")
}

model SaasWorkspace {
  id             String                  @id @default(cuid())
  tenantId       String
  organizationId String?
  slug           String
  name           String
  status         SaasWorkspaceStatus     @default(ACTIVE)
  settingsJson   Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  tenant         SaasTenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization   SaasOrganization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  usageEvents    PlatformUsageEvent[]
  pluginInstalls PlatformPluginInstall[]
  featureFlags   PlatformFeatureFlag[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([organizationId])
  @@index([status])
  @@map("saas_workspaces")
}

model SaasTenantMember {
  id          String     @id @default(cuid())
  tenantId    String
  adminUserId String
  role        String     @default("OWNER")
  enabled     Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      SaasTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adminUser   AdminUser  @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([tenantId, adminUserId])
  @@index([adminUserId])
  @@index([enabled])
  @@map("saas_tenant_members")
}

model SaasPlan {
  id               String             @id @default(cuid())
  code             String             @unique
  name             String
  description      String?
  monthlyPriceCent Int                @default(0)
  annualPriceCent  Int                @default(0)
  limitsJson       Json?
  featuresJson     Json?
  enabled          Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  subscriptions    SaasSubscription[]

  @@index([enabled])
  @@map("saas_plans")
}

model SaasSubscription {
  id           String                 @id @default(cuid())
  tenantId     String
  planId       String
  status       SaasSubscriptionStatus @default(TRIAL)
  billingCycle String                 @default("MONTHLY")
  startsAt     DateTime               @default(now())
  trialEndsAt  DateTime?
  renewsAt     DateTime?
  endsAt       DateTime?
  metadataJson Json?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  tenant       SaasTenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan         SaasPlan               @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([renewsAt])
  @@map("saas_subscriptions")
}

model PlatformApiKey {
  id         String                   @id @default(cuid())
  tenantId   String
  name       String
  keyPrefix  String
  secretHash String
  scopesJson Json?
  status     PlatformCredentialStatus @default(ACTIVE)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdBy  String?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  tenant     SaasTenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, keyPrefix])
  @@index([tenantId])
  @@index([status])
  @@index([expiresAt])
  @@map("platform_api_keys")
}

model PlatformWebhook {
  id                String                   @id @default(cuid())
  tenantId          String
  name              String
  url               String
  signingSecretHash String
  eventsJson        Json?
  status            PlatformCredentialStatus @default(ACTIVE)
  lastDeliveredAt   DateTime?
  lastStatusCode    Int?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  tenant            SaasTenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("platform_webhooks")
}

model PlatformUsageEvent {
  id             String         @id @default(cuid())
  tenantId       String
  workspaceId    String?
  metric         String
  quantity       Int            @default(1)
  unit           String         @default("COUNT")
  idempotencyKey String?
  metadataJson   Json?
  occurredAt     DateTime       @default(now())
  createdAt      DateTime       @default(now())
  tenant         SaasTenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace      SaasWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, metric, occurredAt])
  @@index([workspaceId])
  @@map("platform_usage_events")
}

model PlatformPlugin {
  id           String                  @id @default(cuid())
  code         String                  @unique
  name         String
  version      String
  description  String?
  manifestJson Json
  enabled      Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  installs     PlatformPluginInstall[]

  @@index([enabled])
  @@map("platform_plugins")
}

model PlatformPluginInstall {
  id          String                      @id @default(cuid())
  tenantId    String
  workspaceId String?
  pluginId    String
  scopeKey    String                      @default("tenant")
  status      PlatformPluginInstallStatus @default(ACTIVE)
  configJson  Json?
  installedBy String?
  installedAt DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  tenant      SaasTenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace   SaasWorkspace?              @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  plugin      PlatformPlugin              @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([tenantId, pluginId, scopeKey])
  @@index([workspaceId])
  @@index([status])
  @@map("platform_plugin_installs")
}

model PlatformFeatureFlag {
  id          String         @id @default(cuid())
  tenantId    String
  workspaceId String?
  key         String
  scopeKey    String         @default("tenant")
  enabled     Boolean        @default(false)
  configJson  Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      SaasTenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace   SaasWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key, scopeKey])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([enabled])
  @@map("platform_feature_flags")
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  system      Boolean          @default(false)
  enabled     Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       AdminUserRole[]
  permissions RolePermission[]

  @@index([enabled])
  @@index([createdAt])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  group       String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@index([group])
  @@index([createdAt])
  @@map("permissions")
}

model AdminUserRole {
  id          String    @id @default(cuid())
  adminUserId String
  roleId      String
  createdAt   DateTime  @default(now())
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, roleId])
  @@index([adminUserId])
  @@index([roleId])
  @@map("admin_user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AdminWechatBinding {
  id            String    @id @default(cuid())
  adminUserId   String
  userId        String
  openid        String?
  enabled       Boolean   @default(true)
  boundAt       DateTime  @default(now())
  lastSessionAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  adminUser     AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, userId])
  @@unique([openid])
  @@index([adminUserId])
  @@index([userId])
  @@index([enabled])
  @@map("admin_wechat_bindings")
}

model CheckinStaffAssignment {
  id           String      @id @default(cuid())
  userId       String
  conferenceId String?
  enabled      Boolean     @default(true)
  permissions  Json?
  remark       String?
  createdBy    String?
  disabledAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  conference   Conference? @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conferenceId])
  @@index([enabled])
  @@index([createdAt])
  @@map("checkin_staff_assignments")
}

model Conference {
  id                       String                     @id @default(cuid())
  title                    String
  slug                     String                     @unique
  coverImageUrl            String?
  summary                  String?
  location                 String?
  startsAt                 DateTime
  endsAt                   DateTime
  registrationStartsAt     DateTime?
  registrationEndsAt       DateTime?
  checkInEnabled           Boolean                    @default(false)
  checkInStartsAt          DateTime?
  checkInEndsAt            DateTime?
  checkInMethods           Json?
  checkInFieldBindings     Json?
  groupRegistrationEnabled Boolean                    @default(true)
  maxTicketsPerOrder       Int?
  status                   ConferenceStatus           @default(DRAFT)
  sortOrder                Int                        @default(0)
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  page                     ConferencePage?
  skus                     RegistrationSku[]
  formDefinition           FormDefinition?
  orders                   Order[]
  registrations            Registration[]
  coupons                  Coupon[]
  promotionRules           PromotionRule[]
  registrationCartItems    RegistrationCartItem[]
  inventoryAlertRule       InventoryAlertRule?
  inventoryAlertLogs       InventoryAlertLog[]
  knowledgeBases           KnowledgeBase[]
  aiQuestionLogs           AiQuestionLog[]
  aiSuggestions            AiSuggestion[]
  couponCampaigns          CouponCampaign[]
  appointments             ConferenceAppointment[]
  customerGroupTasks       CustomerGroupMessageTask[]
  wecomCustomerGroups      WecomCustomerGroup[]
  checkinStaffAssignments  CheckinStaffAssignment[]

  @@index([status])
  @@index([createdAt])
  @@index([status, sortOrder])
  @@map("conferences")
}

model WecomIntegration {
  id                         String                  @id @default(cuid())
  name                       String                  @default("default")
  authMode                   WecomAuthMode?
  corpId                     String?
  agentId                    String?
  customerContactSecretEnc   String?
  appSecretEnc               String?
  callbackTokenEnc           String?
  callbackEncodingAesKeyEnc  String?
  groupRobotEnabled          Boolean                 @default(false)
  groupRobotWebhookUrlEnc    String?
  groupRobotSecretEnc        String?
  groupRobotName             String?
  customerContactCallbackUrl String?
  appCallbackUrl             String?
  enabled                    Boolean                 @default(false)
  verified                   Boolean                 @default(false)
  lastTokenCheckedAt         DateTime?
  lastGroupSyncedAt          DateTime?
  lastCallbackAt             DateTime?
  remark                     String?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  accessTokens               WecomAccessTokenCache[]
  customerGroups             WecomCustomerGroup[]
  callbackEvents             WecomCallbackEvent[]

  @@unique([name])
  @@index([enabled])
  @@index([updatedAt])
  @@map("wecom_integrations")
}

model WecomAccessTokenCache {
  id             String           @id @default(cuid())
  integrationId  String
  tokenType      String
  accessTokenEnc String
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  integration    WecomIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, tokenType])
  @@index([expiresAt])
  @@map("wecom_access_token_caches")
}

model WecomCustomerGroup {
  id            String                    @id @default(cuid())
  integrationId String
  conferenceId  String?
  chatId        String?                   @unique
  name          String
  ownerUserId   String?
  ownerName     String?
  groupQrUrl    String?
  joinLink      String?
  status        String                    @default("UNKNOWN")
  syncStatus    String                    @default("MANUAL")
  lastSyncedAt  DateTime?
  rawPayload    Json?
  enabled       Boolean                   @default(true)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  integration   WecomIntegration          @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  conference    Conference?               @relation(fields: [conferenceId], references: [id], onDelete: SetNull)
  messageLogs   CustomerGroupMessageLog[]

  @@index([integrationId])
  @@index([conferenceId])
  @@index([ownerUserId])
  @@index([status])
  @@index([syncStatus])
  @@index([lastSyncedAt])
  @@map("wecom_customer_groups")
}

model WecomCallbackEvent {
  id             String            @id @default(cuid())
  integrationId  String?
  eventSource    String
  eventType      String?
  changeType     String?
  fromUserName   String?
  externalUserId String?
  chatId         String?
  rawPayload     Json?
  decryptedXml   String?
  status         String            @default("RECEIVED")
  errorMessage   String?
  createdAt      DateTime          @default(now())
  integration    WecomIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([integrationId])
  @@index([eventSource])
  @@index([eventType])
  @@index([changeType])
  @@index([chatId])
  @@index([createdAt])
  @@map("wecom_callback_events")
}

model ConferencePage {
  id           String     @id @default(cuid())
  conferenceId String     @unique
  contentJson  Json
  styleJson    Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  conference   Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  @@index([conferenceId])
  @@index([createdAt])
  @@map("conference_pages")
}

model MaterialCategory {
  id          String          @id @default(cuid())
  name        String
  code        String          @unique
  description String?
  sortOrder   Int             @default(0)
  enabled     Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  assets      MaterialAsset[]

  @@index([enabled])
  @@index([sortOrder])
  @@index([createdAt])
  @@map("material_categories")
}

model MaterialAsset {
  id         String            @id @default(cuid())
  categoryId String?
  name       String
  usage      String
  fileType   String
  url        String
  sizeBytes  Int?
  width      Int?
  height     Int?
  enabled    Boolean           @default(true)
  remark     String?
  createdBy  String?
  updatedBy  String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  category   MaterialCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([usage])
  @@index([enabled])
  @@index([createdAt])
  @@map("material_assets")
}

model PageTemplate {
  id                 String           @id @default(cuid())
  pageKey            String           @unique
  title              String
  description        String?
  pageType           String           @default("CUSTOM")
  bindingType        String?
  conferenceId       String?
  productId          String?
  enabled            Boolean          @default(true)
  sortOrder          Int              @default(0)
  publishedVersionId String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  versions           PageVersion[]
  publishLogs        PagePublishLog[]

  @@index([pageType])
  @@index([bindingType])
  @@index([conferenceId])
  @@index([productId])
  @@index([enabled])
  @@index([sortOrder])
  @@index([createdAt])
  @@map("page_templates")
}

model PageVersion {
  id          String           @id @default(cuid())
  templateId  String
  versionNo   Int
  status      String           @default("DRAFT")
  title       String
  components  Json
  themeJson   Json?
  createdBy   String?
  publishedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  template    PageTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  publishLogs PagePublishLog[]

  @@unique([templateId, versionNo])
  @@index([templateId])
  @@index([status])
  @@index([createdAt])
  @@map("page_versions")
}

model ComponentPreset {
  id                String   @id @default(cuid())
  type              String   @unique
  name              String
  group             String
  description       String?
  schemaJson        Json
  defaultConfigJson Json
  enabled           Boolean  @default(true)
  system            Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([group])
  @@index([enabled])
  @@index([sortOrder])
  @@map("component_presets")
}

model ThemePreset {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  configJson  Json
  system      Boolean  @default(false)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@index([createdAt])
  @@map("theme_presets")
}

model ActiveThemeConfig {
  id            String    @id @default(cuid())
  scope         String    @unique @default("global")
  themePresetId String?
  configJson    Json
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([themePresetId])
  @@map("active_theme_configs")
}

model TabBarConfig {
  id        String       @id @default(cuid())
  scope     String       @unique @default("global")
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  items     TabBarItem[]

  @@map("tabbar_configs")
}

model TabBarItem {
  id              String       @id @default(cuid())
  configId        String
  title           String
  iconUrl         String?
  selectedIconUrl String?
  pageKey         String
  path            String
  visible         Boolean      @default(true)
  sortOrder       Int          @default(0)
  requireLogin    Boolean      @default(false)
  badgeText       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  config          TabBarConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([visible])
  @@index([sortOrder])
  @@map("tabbar_items")
}

model PagePublishLog {
  id         String       @id @default(cuid())
  templateId String
