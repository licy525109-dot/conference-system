generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConferenceStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum RegistrationSkuStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  CLOSED
  REFUNDED
}

enum PaymentProvider {
  MOCK
  WECHAT
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CLOSED
}

enum DiscountType {
  FULL_REDUCTION
  COUPON
}

enum CouponType {
  AMOUNT
  PERCENT
}

enum CouponRedemptionStatus {
  PENDING
  USED
  CANCELLED
}

enum RegistrationStatus {
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum CheckInStatus {
  NOT_REQUIRED
  PENDING
  CHECKED_IN
  CANCELLED
}

enum FormFieldType {
  TEXT
  TEXTAREA
  PHONE
  EMAIL
  SELECT
  RADIO
  CHECKBOX
  DATE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  SYSTEM
}

model User {
  id               String         @id @default(cuid())
  openid           String?        @unique
  unionid          String?
  nickname         String?
  wechatNickname   String?
  wechatAvatarUrl  String?
  profileUpdatedAt DateTime?
  lastActiveAt     DateTime?
  phone            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  orders           Order[]
  registrations    Registration[]
  couponRedemptions CouponRedemption[]

  @@index([createdAt])
  @@index([lastActiveAt])
  @@map("users")
}

model AdminUser {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String
  displayName  String?
  enabled      Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]

  @@index([enabled])
  @@index([createdAt])
  @@map("admin_users")
}

model Conference {
  id                   String            @id @default(cuid())
  title                String
  slug                 String            @unique
  coverImageUrl        String?
  summary              String?
  location             String?
  startsAt             DateTime
  endsAt               DateTime
  registrationStartsAt DateTime?
  registrationEndsAt   DateTime?
  checkInEnabled       Boolean           @default(false)
  groupRegistrationEnabled Boolean        @default(true)
  maxTicketsPerOrder   Int?
  status               ConferenceStatus  @default(DRAFT)
  sortOrder            Int               @default(0)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  page                 ConferencePage?
  skus                 RegistrationSku[]
  formDefinition       FormDefinition?
  orders               Order[]
  registrations        Registration[]
  coupons              Coupon[]
  promotionRules       PromotionRule[]

  @@index([status])
  @@index([createdAt])
  @@index([status, sortOrder])
  @@map("conferences")
}

model ConferencePage {
  id           String     @id @default(cuid())
  conferenceId String     @unique
  contentJson  Json
  styleJson    Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  conference   Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  @@index([conferenceId])
  @@index([createdAt])
  @@map("conference_pages")
}

model RegistrationSku {
  id            String                @id @default(cuid())
  conferenceId  String
  name          String
  description   String?
  priceCent     Int
  stock         Int                   @default(0)
  soldCount     Int                   @default(0)
  status        RegistrationSkuStatus @default(ACTIVE)
  saleStartAt   DateTime?
  saleEndAt     DateTime?
  sortOrder     Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  conference    Conference            @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  orders        Order[]
  orderItems    OrderItem[]
  registrations Registration[]
  attendees     RegistrationAttendee[]

  @@unique([conferenceId, name])
  @@index([conferenceId])
  @@index([status])
  @@index([createdAt])
  @@index([conferenceId, status, sortOrder])
  @@map("registration_skus")
}

model FormDefinition {
  id           String      @id @default(cuid())
  conferenceId String      @unique
  title        String?
  description  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  conference   Conference  @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  fields       FormField[]

  @@index([conferenceId])
  @@index([createdAt])
  @@map("form_definitions")
}

model FormField {
  id               String         @id @default(cuid())
  formDefinitionId String
  label            String
  fieldKey         String
  type             FormFieldType
  required         Boolean        @default(false)
  placeholder      String?
  optionsJson      Json?
  validationJson   Json?
  sortOrder        Int            @default(0)
  enabled          Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  formDefinition   FormDefinition @relation(fields: [formDefinitionId], references: [id], onDelete: Cascade)

  @@unique([formDefinitionId, fieldKey])
  @@index([formDefinitionId])
  @@index([type])
  @@index([createdAt])
  @@index([formDefinitionId, sortOrder])
  @@map("form_fields")
}

model Order {
  id                       String          @id @default(cuid())
  orderNo                  String          @unique
  userId                   String?
  conferenceId             String
  skuId                    String
  originAmountCent         Int
  discountAmountCent       Int             @default(0)
  payableAmountCent        Int
  paidAmountCent           Int?
  status                   OrderStatus     @default(PENDING)
  submittedFormJson        Json
  registrationSnapshotJson Json?
  attendeeName             String?
  phone                    String?
  expiredAt                DateTime?
  paidAt                   DateTime?
  closedAt                 DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  user                     User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  conference               Conference      @relation(fields: [conferenceId], references: [id], onDelete: Restrict)
  sku                      RegistrationSku @relation(fields: [skuId], references: [id], onDelete: Restrict)
  items                    OrderItem[]
  discounts                OrderDiscount[]
  couponRedemptions        CouponRedemption[]
  payments                 Payment[]
  registration             Registration?

  @@index([userId])
  @@index([conferenceId])
  @@index([skuId])
  @@index([orderNo])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([conferenceId, status])
  @@map("orders")
}

model OrderDiscount {
  id              String       @id @default(cuid())
  orderId         String
  type            DiscountType
  title           String
  amountCent      Int
  couponId        String?
  promotionRuleId String?
  snapshotJson    Json?
  createdAt       DateTime     @default(now())
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  coupon          Coupon?      @relation(fields: [couponId], references: [id], onDelete: SetNull)
  promotionRule   PromotionRule? @relation(fields: [promotionRuleId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([couponId])
  @@index([promotionRuleId])
  @@index([createdAt])
  @@map("order_discounts")
}

model Coupon {
  id                      String                   @id @default(cuid())
  code                    String                   @unique
  name                    String
  type                    CouponType
  discountAmountCent      Int?
  discountPercent         Int?
  maxDiscountCent         Int?
  minAmountCent           Int?
  minQuantity             Int?
  totalLimit              Int?
  perUserLimit            Int?
  enabled                 Boolean                  @default(true)
  startAt                 DateTime?
  endAt                   DateTime?
  stackableWithPromotion  Boolean                  @default(false)
  conferenceId            String?
  allowedSkuIds           Json?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  conference              Conference?              @relation(fields: [conferenceId], references: [id], onDelete: SetNull)
  discounts               OrderDiscount[]
  redemptions             CouponRedemption[]

  @@index([enabled])
  @@index([conferenceId])
  @@index([createdAt])
  @@map("coupons")
}

model CouponRedemption {
  id        String                 @id @default(cuid())
  couponId  String
  userId    String?
  orderId   String
  status    CouponRedemptionStatus @default(PENDING)
  usedAt    DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  coupon    Coupon                 @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user      User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  order     Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@map("coupon_redemptions")
}

model PromotionRule {
  id                    String          @id @default(cuid())
  name                  String
  type                  DiscountType    @default(FULL_REDUCTION)
  conferenceId          String?
  allowedSkuIds         Json?
  minAmountCent         Int?
  minQuantity           Int?
  discountAmountCent    Int
  enabled               Boolean         @default(true)
  startAt               DateTime?
  endAt                 DateTime?
  stackableWithCoupon   Boolean         @default(false)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  conference            Conference?     @relation(fields: [conferenceId], references: [id], onDelete: SetNull)
  discounts             OrderDiscount[]

  @@index([enabled])
  @@index([conferenceId])
  @@index([createdAt])
  @@map("promotion_rules")
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  skuId           String
  skuName         String
  unitPriceCent   Int
  quantity        Int             @default(1)
  totalAmountCent Int
  createdAt       DateTime        @default(now())
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku             RegistrationSku @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([skuId])
  @@index([createdAt])
  @@map("order_items")
}

model Payment {
  id            String          @id @default(cuid())
  orderId       String
  provider      PaymentProvider @default(MOCK)
  status        PaymentStatus   @default(PENDING)
  outTradeNo    String          @unique
  transactionId String?         @unique
  amountCent    Int
  notifyRawId   String?
  paidAt        DateTime?
  failedReason  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([outTradeNo])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model Registration {
  id             String             @id @default(cuid())
  registrationNo String             @unique
  userId         String?
  conferenceId   String
  skuId          String
  orderId        String             @unique
  attendeeName   String
  phone          String
  formDataJson   Json
  paidAmountCent Int
  status         RegistrationStatus @default(CONFIRMED)
  confirmedAt    DateTime           @default(now())
  adminRemark    String?
  remarkUpdatedAt DateTime?
  remarkUpdatedBy String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  conference     Conference         @relation(fields: [conferenceId], references: [id], onDelete: Restrict)
  sku            RegistrationSku    @relation(fields: [skuId], references: [id], onDelete: Restrict)
  order          Order              @relation(fields: [orderId], references: [id], onDelete: Restrict)
  attendees      RegistrationAttendee[]

  @@index([userId])
  @@index([conferenceId])
  @@index([skuId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([conferenceId, createdAt])
  @@map("registrations")
}

model RegistrationAttendee {
  id             String        @id @default(cuid())
  registrationId String
  skuId          String
  name           String
  phone          String
  company        String?
  title          String?
  formDataJson   Json?
  checkInStatus  CheckInStatus @default(NOT_REQUIRED)
  checkedInAt    DateTime?
  checkedInBy    String?
  adminRemark    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  registration   Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  sku            RegistrationSku @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@index([registrationId])
  @@index([skuId])
  @@index([checkInStatus])
  @@index([createdAt])
  @@map("registration_attendees")
}

model AuditLog {
  id           String      @id @default(cuid())
  adminUserId  String?
  action       AuditAction
  entityType   String
  entityId     String?
  summary      String?
  metadataJson Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())
  adminUser    AdminUser?  @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}
