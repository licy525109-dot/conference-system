generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConferenceStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum RegistrationSkuStatus {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  CLOSED
  REFUNDED
}

enum PaymentProvider {
  MOCK
  WECHAT
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CLOSED
}

enum DiscountType {
  FULL_REDUCTION
  COUPON
}

enum CouponType {
  AMOUNT
  PERCENT
}

enum CouponRedemptionStatus {
  PENDING
  USED
  CANCELLED
}

enum RegistrationStatus {
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum CheckInStatus {
  NOT_REQUIRED
  PENDING
  CHECKED_IN
  CANCELLED
}

enum FormFieldType {
  TEXT
  TEXTAREA
  PHONE
  EMAIL
  SELECT
  RADIO
  CHECKBOX
  DATE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  SYSTEM
}

enum NotificationChannelType {
  MOCK
  WECHAT_SUBSCRIBE
  SMS
}

enum NotificationTemplateStatus {
  DRAFT
  ACTIVE
  DISABLED
}

enum NotificationTaskStatus {
  DRAFT
  PENDING
  SENDING
  SENT
  PARTIAL_FAILED
  FAILED
  CANCELLED
}

enum NotificationLogStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

model User {
  id                        String                     @id @default(cuid())
  openid                    String?                    @unique
  unionid                   String?
  nickname                  String?
  wechatNickname            String?
  wechatAvatarUrl           String?
  profileUpdatedAt          DateTime?
  lastActiveAt              DateTime?
  phone                     String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  orders                    Order[]
  registrations             Registration[]
  couponRedemptions         CouponRedemption[]
  memberships               UserMembership[]
  cartItems                 CartItem[]
  registrationCartItems     RegistrationCartItem[]
  mallOrders                MallOrder[]
  notificationSubscriptions NotificationSubscription[]
  notificationLogs          NotificationLog[]
  adminWechatBindings       AdminWechatBinding[]

  @@index([createdAt])
  @@index([lastActiveAt])
  @@map("users")
}

model AdminUser {
  id                    String                 @id @default(cuid())
  username              String                 @unique
  passwordHash          String
  displayName           String?
  enabled               Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  auditLogs             AuditLog[]
  roles                 AdminUserRole[]
  mobileBindings        AdminWechatBinding[]
  notificationTemplates NotificationTemplate[] @relation("NotificationTemplateCreatedBy")
  notificationTasks     NotificationTask[]     @relation("NotificationTaskCreatedBy")

  @@index([enabled])
  @@index([createdAt])
  @@map("admin_users")
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  system      Boolean          @default(false)
  enabled     Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       AdminUserRole[]
  permissions RolePermission[]

  @@index([enabled])
  @@index([createdAt])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  group       String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@index([group])
  @@index([createdAt])
  @@map("permissions")
}

model AdminUserRole {
  id          String    @id @default(cuid())
  adminUserId String
  roleId      String
  createdAt   DateTime  @default(now())
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, roleId])
  @@index([adminUserId])
  @@index([roleId])
  @@map("admin_user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AdminWechatBinding {
  id            String    @id @default(cuid())
  adminUserId   String
  userId        String
  openid        String?
  enabled       Boolean   @default(true)
  boundAt       DateTime  @default(now())
  lastSessionAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  adminUser     AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, userId])
  @@unique([openid])
  @@index([adminUserId])
  @@index([userId])
  @@index([enabled])
  @@map("admin_wechat_bindings")
}

model Conference {
  id                       String                 @id @default(cuid())
  title                    String
  slug                     String                 @unique
  coverImageUrl            String?
  summary                  String?
  location                 String?
  startsAt                 DateTime
  endsAt                   DateTime
  registrationStartsAt     DateTime?
  registrationEndsAt       DateTime?
  checkInEnabled           Boolean                @default(false)
  groupRegistrationEnabled Boolean                @default(true)
  maxTicketsPerOrder       Int?
  status                   ConferenceStatus       @default(DRAFT)
  sortOrder                Int                    @default(0)
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  page                     ConferencePage?
  skus                     RegistrationSku[]
  formDefinition           FormDefinition?
  orders                   Order[]
  registrations            Registration[]
  coupons                  Coupon[]
  promotionRules           PromotionRule[]
  registrationCartItems    RegistrationCartItem[]

  @@index([status])
  @@index([createdAt])
  @@index([status, sortOrder])
  @@map("conferences")
}

model ConferencePage {
  id           String     @id @default(cuid())
  conferenceId String     @unique
  contentJson  Json
  styleJson    Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  conference   Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  @@index([conferenceId])
  @@index([createdAt])
  @@map("conference_pages")
}

model MaterialCategory {
  id          String          @id @default(cuid())
  name        String
  code        String          @unique
  description String?
  sortOrder   Int             @default(0)
  enabled     Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  assets      MaterialAsset[]

  @@index([enabled])
  @@index([sortOrder])
  @@index([createdAt])
  @@map("material_categories")
}

model MaterialAsset {
  id         String            @id @default(cuid())
  categoryId String?
  name       String
  usage      String
  fileType   String
  url        String
  sizeBytes  Int?
  width      Int?
  height     Int?
  enabled    Boolean           @default(true)
  remark     String?
  createdBy  String?
  updatedBy  String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  category   MaterialCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([usage])
  @@index([enabled])
  @@index([createdAt])
  @@map("material_assets")
}

model PageTemplate {
  id                 String           @id @default(cuid())
  pageKey            String           @unique
  title              String
  description        String?
  pageType           String           @default("CUSTOM")
  enabled            Boolean          @default(true)
  sortOrder          Int              @default(0)
  publishedVersionId String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  versions           PageVersion[]
  publishLogs        PagePublishLog[]

  @@index([pageType])
  @@index([enabled])
  @@index([sortOrder])
  @@index([createdAt])
  @@map("page_templates")
}

model PageVersion {
  id          String           @id @default(cuid())
  templateId  String
  versionNo   Int
  status      String           @default("DRAFT")
  title       String
  components  Json
  themeJson   Json?
  createdBy   String?
  publishedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  template    PageTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  publishLogs PagePublishLog[]

  @@unique([templateId, versionNo])
  @@index([templateId])
  @@index([status])
  @@index([createdAt])
  @@map("page_versions")
}

model ComponentPreset {
  id                String   @id @default(cuid())
  type              String   @unique
  name              String
  group             String
  description       String?
  schemaJson        Json
  defaultConfigJson Json
  enabled           Boolean  @default(true)
  system            Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([group])
  @@index([enabled])
  @@index([sortOrder])
  @@map("component_presets")
}

model ThemePreset {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  configJson  Json
  system      Boolean  @default(false)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@index([createdAt])
  @@map("theme_presets")
}

model ActiveThemeConfig {
  id            String    @id @default(cuid())
  scope         String    @unique @default("global")
  themePresetId String?
  configJson    Json
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([themePresetId])
  @@map("active_theme_configs")
}

model TabBarConfig {
  id        String       @id @default(cuid())
  scope     String       @unique @default("global")
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  items     TabBarItem[]

  @@map("tabbar_configs")
}

model TabBarItem {
  id              String       @id @default(cuid())
  configId        String
  title           String
  iconUrl         String?
  selectedIconUrl String?
  pageKey         String
  path            String
  visible         Boolean      @default(true)
  sortOrder       Int          @default(0)
  requireLogin    Boolean      @default(false)
  badgeText       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  config          TabBarConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([visible])
  @@index([sortOrder])
  @@map("tabbar_items")
}

model PagePublishLog {
  id         String       @id @default(cuid())
  templateId String
  versionId  String?
  action     String
  summary    String?
  createdBy  String?
  createdAt  DateTime     @default(now())
  template   PageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version    PageVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([versionId])
  @@index([action])
  @@index([createdAt])
  @@map("page_publish_logs")
}

model MemberLevel {
  id              String                @id @default(cuid())
  code            String                @unique
  name            String
  description     String?
  rank            Int                   @default(0)
  priceCent       Int                   @default(0)
  discountPercent Int?
  enabled         Boolean               @default(true)
  benefitsJson    Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  benefits        MemberBenefit[]
  memberships     UserMembership[]
  priceRules      MembershipPriceRule[]

  @@index([enabled])
  @@index([rank])
  @@map("member_levels")
}

model MemberBenefit {
  id          String      @id @default(cuid())
  levelId     String
  title       String
  description String?
  type        String
  configJson  Json?
  enabled     Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  level       MemberLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@index([levelId])
  @@index([enabled])
  @@index([sortOrder])
  @@map("member_benefits")
}

model UserMembership {
  id        String      @id @default(cuid())
  userId    String
  levelId   String
  status    String      @default("ACTIVE")
  startsAt  DateTime    @default(now())
  endsAt    DateTime?
  source    String?
  remark    String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  level     MemberLevel @relation(fields: [levelId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([levelId])
  @@index([status])
  @@index([endsAt])
  @@map("user_memberships")
}

model MembershipOrder {
  id           String    @id @default(cuid())
  orderNo      String    @unique
  userId       String?
  levelId      String
  amountCent   Int
  status       String    @default("PENDING")
  paidAt       DateTime?
  snapshotJson Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([levelId])
  @@index([status])
  @@index([createdAt])
  @@map("membership_orders")
}

model MembershipPriceRule {
  id              String      @id @default(cuid())
  levelId         String
  conferenceId    String?
  skuId           String?
  discountPercent Int?
  discountCent    Int?
  enabled         Boolean     @default(true)
  startAt         DateTime?
  endAt           DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  level           MemberLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)

  @@index([levelId])
  @@index([conferenceId])
  @@index([skuId])
  @@index([enabled])
  @@map("membership_price_rules")
}

model FinanceReconciliationBatch {
  id          String                      @id @default(cuid())
  batchNo     String                      @unique
  status      String                      @default("CREATED")
  source      String                      @default("LOCAL")
  startedAt   DateTime?
  finishedAt  DateTime?
  summaryJson Json?
  createdBy   String?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  items       FinanceReconciliationItem[]

  @@index([status])
  @@index([createdAt])
  @@map("finance_reconciliation_batches")
}

model FinanceReconciliationItem {
  id               String                     @id @default(cuid())
  batchId          String
  orderNo          String?
  outTradeNo       String?
  transactionId    String?
  localAmountCent  Int?
  remoteAmountCent Int?
  type             String
  status           String                     @default("OPEN")
  detailJson       Json?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  batch            FinanceReconciliationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([type])
  @@index([status])
  @@index([orderNo])
  @@index([outTradeNo])
  @@map("finance_reconciliation_items")
}

model WechatBillImport {
  id        String   @id @default(cuid())
  fileName  String
  status    String   @default("UPLOADED")
  rowCount  Int      @default(0)
  errorJson Json?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("wechat_bill_imports")
}

model RefundRecord {
  id         String   @id @default(cuid())
  orderNo    String?
  amountCent Int
  status     String   @default("RESERVED")
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orderNo])
  @@index([status])
  @@map("refund_records")
}

model InvoiceRecord {
  id         String   @id @default(cuid())
  orderNo    String?
  title      String
  amountCent Int
  status     String   @default("RESERVED")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orderNo])
  @@index([status])
  @@map("invoice_records")
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  description String?
  enabled     Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([enabled])
  @@index([sortOrder])
  @@map("product_categories")
}

model Product {
  id              String           @id @default(cuid())
  categoryId      String?
  title           String
  subtitle        String?
  descriptionJson Json?
  coverImageUrl   String?
  status          String           @default("DRAFT")
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  skus            ProductSku[]
  images          ProductImage[]

  @@index([categoryId])
  @@index([status])
  @@index([sortOrder])
  @@map("products")
}

model ProductSku {
  id             String          @id @default(cuid())
  productId      String
  name           String
  priceCent      Int
  stock          Int             @default(0)
  soldCount      Int             @default(0)
  status         String          @default("ACTIVE")
  specsJson      Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems      CartItem[]
  mallOrderItems MallOrderItem[]

  @@index([productId])
  @@index([status])
  @@map("product_skus")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sortOrder])
  @@map("product_images")
}

model CartItem {
  id        String     @id @default(cuid())
  userId    String
  skuId     String
  quantity  Int        @default(1)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sku       ProductSku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([userId, skuId])
  @@index([userId])
  @@index([skuId])
  @@map("cart_items")
}

model RegistrationCartItem {
  id            String          @id @default(cuid())
  userId        String
  conferenceId  String
  skuId         String
  quantity      Int             @default(1)
  couponCode    String?
  attendeesJson Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  conference    Conference      @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  sku           RegistrationSku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conferenceId])
  @@index([skuId])
  @@map("registration_cart_items")
}

model MallOrder {
  id                 String          @id @default(cuid())
  orderNo            String          @unique
  userId             String?
  originAmountCent   Int
  discountAmountCent Int             @default(0)
  payableAmountCent  Int
  paidAmountCent     Int?
  status             String          @default("PENDING")
  receiverName       String?
  receiverPhone      String?
  receiverAddress    String?
  remark             String?
  paidAt             DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  user               User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  items              MallOrderItem[]
  shipments          MallShipment[]
  afterSales         MallAfterSale[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("mall_orders")
}

model MallOrderItem {
  id              String     @id @default(cuid())
  orderId         String
  skuId           String
  productTitle    String
  skuName         String
  unitPriceCent   Int
  quantity        Int
  totalAmountCent Int
  createdAt       DateTime   @default(now())
  order           MallOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku             ProductSku @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([skuId])
  @@map("mall_order_items")
}

model MallShipment {
  id         String    @id @default(cuid())
  orderId    String
  company    String?
  trackingNo String?
  status     String    @default("PENDING")
  shippedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  order      MallOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("mall_shipments")
}

model MallAfterSale {
  id        String    @id @default(cuid())
  orderId   String
  type      String
  status    String    @default("PENDING")
  reason    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  order     MallOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@map("mall_after_sales")
}

model RegistrationSku {
  id            String                 @id @default(cuid())
  conferenceId  String
  name          String
  description   String?
  priceCent     Int
  stock         Int                    @default(0)
  soldCount     Int                    @default(0)
  status        RegistrationSkuStatus  @default(ACTIVE)
  saleStartAt   DateTime?
  saleEndAt     DateTime?
  sortOrder     Int                    @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  conference    Conference             @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  orders        Order[]
  orderItems    OrderItem[]
  registrations Registration[]
  attendees     RegistrationAttendee[]
  cartItems     RegistrationCartItem[]

  @@unique([conferenceId, name])
  @@index([conferenceId])
  @@index([status])
  @@index([createdAt])
  @@index([conferenceId, status, sortOrder])
  @@map("registration_skus")
}

model FormDefinition {
  id           String      @id @default(cuid())
  conferenceId String      @unique
  title        String?
  description  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  conference   Conference  @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  fields       FormField[]

  @@index([conferenceId])
  @@index([createdAt])
  @@map("form_definitions")
}

model FormField {
  id               String         @id @default(cuid())
  formDefinitionId String
  label            String
  fieldKey         String
  type             FormFieldType
  required         Boolean        @default(false)
  placeholder      String?
  optionsJson      Json?
  validationJson   Json?
  sortOrder        Int            @default(0)
  enabled          Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  formDefinition   FormDefinition @relation(fields: [formDefinitionId], references: [id], onDelete: Cascade)

  @@unique([formDefinitionId, fieldKey])
  @@index([formDefinitionId])
  @@index([type])
  @@index([createdAt])
  @@index([formDefinitionId, sortOrder])
  @@map("form_fields")
}

model Order {
  id                       String             @id @default(cuid())
  orderNo                  String             @unique
  userId                   String?
  conferenceId             String
  skuId                    String
  originAmountCent         Int
  discountAmountCent       Int                @default(0)
  payableAmountCent        Int
  paidAmountCent           Int?
  status                   OrderStatus        @default(PENDING)
  submittedFormJson        Json
  registrationSnapshotJson Json?
  attendeeName             String?
  phone                    String?
  expiredAt                DateTime?
  paidAt                   DateTime?
  closedAt                 DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  user                     User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  conference               Conference         @relation(fields: [conferenceId], references: [id], onDelete: Restrict)
  sku                      RegistrationSku    @relation(fields: [skuId], references: [id], onDelete: Restrict)
  items                    OrderItem[]
  discounts                OrderDiscount[]
  couponRedemptions        CouponRedemption[]
  payments                 Payment[]
  registration             Registration?

  @@index([userId])
  @@index([conferenceId])
  @@index([skuId])
  @@index([orderNo])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([conferenceId, status])
  @@map("orders")
}

model OrderDiscount {
  id              String         @id @default(cuid())
  orderId         String
  type            DiscountType
  title           String
  amountCent      Int
  couponId        String?
  promotionRuleId String?
  snapshotJson    Json?
  createdAt       DateTime       @default(now())
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  coupon          Coupon?        @relation(fields: [couponId], references: [id], onDelete: SetNull)
  promotionRule   PromotionRule? @relation(fields: [promotionRuleId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([couponId])
  @@index([promotionRuleId])
  @@index([createdAt])
  @@map("order_discounts")
}

model Coupon {
  id                     String             @id @default(cuid())
  code                   String             @unique
  name                   String
  type                   CouponType
  discountAmountCent     Int?
  discountPercent        Int?
  maxDiscountCent        Int?
  minAmountCent          Int?
  minQuantity            Int?
  totalLimit             Int?
  perUserLimit           Int?
  enabled                Boolean            @default(true)
  startAt                DateTime?
  endAt                  DateTime?
  stackableWithPromotion Boolean            @default(false)
  conferenceId           String?
  allowedSkuIds          Json?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  conference             Conference?        @relation(fields: [conferenceId], references: [id], onDelete: SetNull)
  discounts              OrderDiscount[]
  redemptions            CouponRedemption[]

  @@index([enabled])
  @@index([conferenceId])
  @@index([createdAt])
  @@map("coupons")
}

model CouponRedemption {
  id        String                 @id @default(cuid())
  couponId  String
  userId    String?
  orderId   String
  status    CouponRedemptionStatus @default(PENDING)
  usedAt    DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  coupon    Coupon                 @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user      User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  order     Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@map("coupon_redemptions")
}

model PromotionRule {
  id                  String          @id @default(cuid())
  name                String
  type                DiscountType    @default(FULL_REDUCTION)
  conferenceId        String?
  allowedSkuIds       Json?
  minAmountCent       Int?
  minQuantity         Int?
  discountAmountCent  Int
  enabled             Boolean         @default(true)
  startAt             DateTime?
  endAt               DateTime?
  stackableWithCoupon Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  conference          Conference?     @relation(fields: [conferenceId], references: [id], onDelete: SetNull)
  discounts           OrderDiscount[]

  @@index([enabled])
  @@index([conferenceId])
  @@index([createdAt])
  @@map("promotion_rules")
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  skuId           String
  skuName         String
  unitPriceCent   Int
  quantity        Int             @default(1)
  totalAmountCent Int
  createdAt       DateTime        @default(now())
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku             RegistrationSku @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([skuId])
  @@index([createdAt])
  @@map("order_items")
}

model Payment {
  id            String          @id @default(cuid())
  orderId       String
  provider      PaymentProvider @default(MOCK)
  status        PaymentStatus   @default(PENDING)
  outTradeNo    String          @unique
  transactionId String?         @unique
  amountCent    Int
  notifyRawId   String?
  paidAt        DateTime?
  failedReason  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([outTradeNo])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model Registration {
  id              String                 @id @default(cuid())
  registrationNo  String                 @unique
  userId          String?
  conferenceId    String
  skuId           String
  orderId         String                 @unique
  attendeeName    String
  phone           String
  formDataJson    Json
  paidAmountCent  Int
  status          RegistrationStatus     @default(CONFIRMED)
  confirmedAt     DateTime               @default(now())
  adminRemark     String?
  remarkUpdatedAt DateTime?
  remarkUpdatedBy String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  user            User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  conference      Conference             @relation(fields: [conferenceId], references: [id], onDelete: Restrict)
  sku             RegistrationSku        @relation(fields: [skuId], references: [id], onDelete: Restrict)
  order           Order                  @relation(fields: [orderId], references: [id], onDelete: Restrict)
  attendees       RegistrationAttendee[]

  @@index([userId])
  @@index([conferenceId])
  @@index([skuId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([conferenceId, createdAt])
  @@map("registrations")
}

model RegistrationAttendee {
  id             String          @id @default(cuid())
  registrationId String
  skuId          String
  name           String
  phone          String
  company        String?
  title          String?
  formDataJson   Json?
  checkInStatus  CheckInStatus   @default(NOT_REQUIRED)
  checkedInAt    DateTime?
  checkedInBy    String?
  adminRemark    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  registration   Registration    @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  sku            RegistrationSku @relation(fields: [skuId], references: [id], onDelete: Restrict)

  @@index([registrationId])
  @@index([skuId])
  @@index([checkInStatus])
  @@index([createdAt])
  @@map("registration_attendees")
}

model AuditLog {
  id           String      @id @default(cuid())
  adminUserId  String?
  action       AuditAction
  entityType   String
  entityId     String?
  summary      String?
  metadataJson Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())
  adminUser    AdminUser?  @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model NotificationSubscription {
  id           String                  @id @default(cuid())
  userId       String
  channel      NotificationChannelType
  templateCode String
  openid       String?
  phone        String?
  enabled      Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel, templateCode])
  @@index([userId])
  @@index([channel])
  @@index([templateCode])
  @@index([enabled])
  @@map("notification_subscriptions")
}

model NotificationTemplate {
  id          String                     @id @default(cuid())
  code        String                     @unique
  name        String
  channel     NotificationChannelType
  status      NotificationTemplateStatus @default(DRAFT)
  title       String?
  templateKey String?
  contentJson Json
  remark      String?
  createdById String?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  createdBy   AdminUser?                 @relation("NotificationTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  tasks       NotificationTask[]
  logs        NotificationLog[]

  @@index([channel])
  @@index([status])
  @@index([createdAt])
  @@map("notification_templates")
}

model NotificationTask {
  id          String                  @id @default(cuid())
  name        String
  templateId  String
  channel     NotificationChannelType
  targetType  String                  @default("MANUAL")
  payloadJson Json?
  status      NotificationTaskStatus  @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdById String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  template    NotificationTemplate    @relation(fields: [templateId], references: [id], onDelete: Restrict)
  createdBy   AdminUser?              @relation("NotificationTaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  logs        NotificationLog[]

  @@index([templateId])
  @@index([channel])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
  @@map("notification_tasks")
}

model NotificationLog {
  id                String                  @id @default(cuid())
  taskId            String?
  templateId        String?
  userId            String?
  channel           NotificationChannelType
  recipient         String?
  status            NotificationLogStatus   @default(PENDING)
  providerMessageId String?
  errorCode         String?
  errorMessage      String?
  payloadJson       Json?
  sentAt            DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  task              NotificationTask?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  template          NotificationTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  user              User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([templateId])
  @@index([userId])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
  @@map("notification_logs")
}
