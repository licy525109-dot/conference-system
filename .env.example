NODE_ENV=development
API_PORT=3001
VITE_API_BASE_URL="http://localhost:3001/api"
VITE_MP_WEIXIN_API_BASE_URL="http://127.0.0.1:3001/api"
VITE_PAYMENT_MODE="mock"
DATABASE_URL="postgresql://conference:conference_dev_password@localhost:5432/conference_dev?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="dev_jwt_secret_change_me"
ADMIN_DEFAULT_EMAIL="admin@example.com"
ADMIN_DEFAULT_PASSWORD="change-me-in-production"

# WeChat Mini Program login
# Keep mock for local H5 development. Set to real only in mp-weixin environments with real credentials.
WECHAT_LOGIN_MODE=mock
WECHAT_APP_ID="replace-with-your-wechat-app-id"
WECHAT_APP_SECRET="replace-with-your-wechat-app-secret"

# WeChat Pay
WECHAT_PAY_MODE=mock
WECHAT_PAY_ENABLED=false
WECHAT_PAY_MOCK=true
WECHAT_PAY_MCH_ID="replace-with-your-mch-id"
WECHAT_PAY_APP_ID=""
WECHAT_PAY_MCH_SERIAL_NO=""
WECHAT_PAY_API_V3_KEY="replace-with-your-api-v3-key"
WECHAT_PAY_PRIVATE_KEY_PATH="/path/to/apiclient_key.pem"
WECHAT_PAY_NOTIFY_URL="https://your-domain.com/api/payments/wechat/notify"
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=""


# Payment mode aliases used by docs and Codex prompts
PAYMENT_MODE=mock
